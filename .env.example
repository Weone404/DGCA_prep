# PostgreSQL Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
NODE_ENV=development

# Supabase config (optional)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_OR_ANON_KEY

# Public app config used across all pages
NEXT_PUBLIC_APP_NAME=WeOne aviation
NEXT_PUBLIC_APP_TAGLINE=Learn From Home
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Public demo auth user for login page
NEXT_PUBLIC_DEFAULT_USER_NAME=Demo User
NEXT_PUBLIC_DEFAULT_USER_EMAIL=demo@example.com
NEXT_PUBLIC_DEFAULT_USER_PASSWORD=Demo@1234
NEXT_PUBLIC_DEFAULT_USER_ROLE=Student
NEXT_PUBLIC_DEFAULT_USER_AVATAR=https://api.dicebear.com/7.x/avataaars/svg?seed=Demo

# Optional additional quick-login users (JSON array)
# NEXT_PUBLIC_SAMPLE_USERS_JSON=[{"name":"Puja","email":"puja@example.com","password":"Puja@1234","role":"VIP"}]
